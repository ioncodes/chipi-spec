            | "fadd{rc ? .} {fd}, {fa}, {fb}"

fsqrtx      [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:25]=00000 [26:30]=10110 rc:bool[31]
            | "fsqrt{rc ? .} {fd}, {fb}"

fselx       [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=10111 rc:bool[31]
            | "fsel{rc ? .} {fd}, {fa}, {fc}, {fb}"

fmulx       [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] [16:20]=00000 fc:fpr[21:25] [26:30]=11001 rc:bool[31]
            | "fmul{rc ? .} {fd}, {fa}, {fc}"

frsqrtex    [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:25]=00000 [26:30]=11010 rc:bool[31]
            | "frsqrte{rc ? .} {fd}, {fb}"

fmsubx      [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11100 rc:bool[31]
            | "fmsub{rc ? .} {fd}, {fa}, {fc}, {fb}"

fmaddx      [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11101 rc:bool[31]
            | "fmadd{rc ? .} {fd}, {fa}, {fc}, {fb}"

fnmsubx     [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11110 rc:bool[31]
            | "fnmsub{rc ? .} {fd}, {fa}, {fc}, {fb}"

fnmaddx     [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11111 rc:bool[31]
            | "fnmadd{rc ? .} {fd}, {fa}, {fc}, {fb}"

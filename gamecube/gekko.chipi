# Primary opcodes 56-57: Paired Singles Quantized Load
# ============================================================
psq_l       [0:5]=111000 fd:fpr[6:10] ra:gpr[11:15] w:bool[16] i:u3[17:19] d:simm12[20:31]
            | "psq_l {fd}, {d}({ra}), {w}, {i}"

psq_lu      [0:5]=111001 fd:fpr[6:10] ra:gpr[11:15] w:bool[16] i:u3[17:19] d:simm12[20:31]
            | "psq_lu {fd}, {d}({ra}), {w}, {i}"

# ============================================================
# Primary opcode 59: FP Single Arithmetic A-form
# ============================================================
fdivsx      [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10010 rc:bool[31]
            | "fdivs{rc ? .} {fd}, {fa}, {fb}"

fsubsx      [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10100 rc:bool[31]
            | "fsubs{rc ? .} {fd}, {fa}, {fb}"

faddsx      [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10101 rc:bool[31]
            | "fadds{rc ? .} {fd}, {fa}, {fb}"

fsqrtsx     [0:5]=111011 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:25]=00000 [26:30]=10110 rc:bool[31]
            | "fsqrts{rc ? .} {fd}, {fb}"

fresx       [0:5]=111011 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:25]=00000 [26:30]=11000 rc:bool[31]
            | "fres{rc ? .} {fd}, {fb}"

fmulsx      [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] [16:20]=00000 fc:fpr[21:25] [26:30]=11001 rc:bool[31]
            | "fmuls{rc ? .} {fd}, {fa}, {fc}"

fmsubsx     [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11100 rc:bool[31]
            | "fmsubs{rc ? .} {fd}, {fa}, {fc}, {fb}"

fmaddsx     [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11101 rc:bool[31]
            | "fmadds{rc ? .} {fd}, {fa}, {fc}, {fb}"

fnmsubsx    [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11110 rc:bool[31]
            | "fnmsubs{rc ? .} {fd}, {fa}, {fc}, {fb}"

fnmaddsx    [0:5]=111011 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11111 rc:bool[31]
            | "fnmadds{rc ? .} {fd}, {fa}, {fc}, {fb}"

# ============================================================
# Primary opcodes 60-61: Paired Singles Quantized Store
# ============================================================
psq_st      [0:5]=111100 fs:fpr[6:10] ra:gpr[11:15] w:bool[16] i:u3[17:19] d:simm12[20:31]
            | "psq_st {fs}, {d}({ra}), {w}, {i}"

psq_stu     [0:5]=111101 fs:fpr[6:10] ra:gpr[11:15] w:bool[16] i:u3[17:19] d:simm12[20:31]
            | "psq_stu {fs}, {d}({ra}), {w}, {i}"

# ============================================================
# Primary opcode 63: FP Double X-form and A-form
# ============================================================

# FP Compare X-form
fcmpu       [0:5]=111111 crfd:u3[6:8] [9:10]=00 fa:fpr[11:15] fb:fpr[16:20] [21:30]=0000000000 [31]=0
            | "fcmpu cr{crfd}, {fa}, {fb}"

# FP Move/Convert X-form (10-bit XO at [21:30])
frspx       [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0000001100 rc:bool[31]
            | "frsp{rc ? .} {fd}, {fb}"

fctiwx      [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0000001110 rc:bool[31]
            | "fctiw{rc ? .} {fd}, {fb}"

fctiwzx     [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0000001111 rc:bool[31]
            | "fctiwz{rc ? .} {fd}, {fb}"

fcmpo       [0:5]=111111 crfd:u3[6:8] [9:10]=00 fa:fpr[11:15] fb:fpr[16:20] [21:30]=0000100000 [31]=0
            | "fcmpo cr{crfd}, {fa}, {fb}"

mtfsb1x     [0:5]=111111 crbd:u5[6:10] [11:20]=0000000000 [21:30]=0000100110 rc:bool[31]
            | "mtfsb1{rc ? .} {crbd}"

fnegx       [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0000101000 rc:bool[31]
            | "fneg{rc ? .} {fd}, {fb}"

mcrfs       [0:5]=111111 crfd:u3[6:8] [9:10]=00 crfs:u3[11:13] [14:20]=0000000 [21:30]=0001000000 [31]=0
            | "mcrfs cr{crfd}, cr{crfs}"

mtfsb0x     [0:5]=111111 crbd:u5[6:10] [11:20]=0000000000 [21:30]=0001000110 rc:bool[31]
            | "mtfsb0{rc ? .} {crbd}"

fmrx        [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0001001000 rc:bool[31]
            | "fmr{rc ? .} {fd}, {fb}"

mtfsfix     [0:5]=111111 crfd:u3[6:8] [9:10]=00 [11:15]=00000 imm:u4[16:19] [20]=0 [21:30]=0010000110 rc:bool[31]
            | "mtfsfi{rc ? .} cr{crfd}, {imm}"

fnabsx      [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0010001000 rc:bool[31]
            | "fnabs{rc ? .} {fd}, {fb}"

fabsx       [0:5]=111111 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0100001000 rc:bool[31]
            | "fabs{rc ? .} {fd}, {fb}"

mffsx       [0:5]=111111 fd:fpr[6:10] [11:20]=0000000000 [21:30]=1001000111 rc:bool[31]
            | "mffs{rc ? .} {fd}"

mtfsfx      [0:5]=111111 [6]=0 fm:u8[7:14] [15]=0 fb:fpr[16:20] [21:30]=1011000111 rc:bool[31]
            | "mtfsf{rc ? .} {fm}, {fb}"

# FP Double Arithmetic A-form (5-bit XO at [26:30])
fdivx       [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10010 rc:bool[31]
            | "fdiv{rc ? .} {fd}, {fa}, {fb}"

fsubx       [0:5]=111111 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10100 rc:bool[31]
            | "fsub{rc ? .} {fd}, {fa}, {fb}"


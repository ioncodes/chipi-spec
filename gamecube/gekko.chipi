# Gekko (PowerPC 750) - Nintendo GameCube CPU
# 32-bit opcodes, MSB0 bit ordering

import crate::cpu::Gpr
import crate::cpu::Fpr

decoder Gekko {
    width = 32
    bit_order = msb0
    endian = big
}

type gpr = u8 as Gpr
type fpr = u8 as Fpr
type uimm = u16 { display(hex) }
type simm12 = i32 { sign_extend(12), display(signed_hex) }
type simm16 = i32 { sign_extend(16), display(signed_hex) }
type simm24 = i32 { sign_extend(24), shift_left(2), display(signed_hex) }
type disp = i32 { sign_extend(16), display(signed_hex) }
type branch_disp = i32 { sign_extend(14), shift_left(2), display(signed_hex) }

map bc_cond_true(cond_bit) {
    0 => "lt"
    1 => "gt"
    2 => "eq"
    3 => "so"
}

map bc_cond_false(cond_bit) {
    0 => "ge"
    1 => "le"
    2 => "ne"
    3 => "ns"
}

map bc_cr_prefix(cr_num) {
    0 => ""
    _ => "cr{cr_num}, "
}

map bc_hint(y) {
    0 => ""
    _ => "+"
}

map bclr_cr(cr_num) {
    0 => ""
    _ => " cr{cr_num}"
}

map spr_name(spr) {
    1 => "xer"
    8 => "lr"
    9 => "ctr"
    18 => "dsisr"
    19 => "dar"
    22 => "dec"
    25 => "sdr1"
    26 => "srr0"
    27 => "srr1"
    272 => "sprg0"
    273 => "sprg1"
    274 => "sprg2"
    275 => "sprg3"
    268 => "tbl"
    269 => "tbu"
    282 => "ear"
    284 => "tbl"
    285 => "tbu"
    287 => "pvr"
    528 => "ibat0u"
    529 => "ibat0l"
    530 => "ibat1u"
    531 => "ibat1l"
    532 => "ibat2u"
    533 => "ibat2l"
    534 => "ibat3u"
    535 => "ibat3l"
    536 => "dbat0u"
    537 => "dbat0l"
    538 => "dbat1u"
    539 => "dbat1l"
    540 => "dbat2u"
    541 => "dbat2l"
    542 => "dbat3u"
    543 => "dbat3l"
    912 => "gqr0"
    913 => "gqr1"
    914 => "gqr2"
    915 => "gqr3"
    916 => "gqr4"
    917 => "gqr5"
    918 => "gqr6"
    919 => "gqr7"
    920 => "hid2"
    921 => "wpar"
    922 => "dmau"
    923 => "dmal"
    936 => "ummcr0"
    937 => "upmc1"
    938 => "upmc2"
    939 => "usia"
    940 => "ummcr1"
    941 => "upmc3"
    942 => "upmc4"
    943 => "usda"
    952 => "mmcr0"
    953 => "pmc1"
    954 => "pmc2"
    955 => "sia"
    956 => "mmcr1"
    957 => "pmc3"
    958 => "pmc4"
    959 => "sda"
    1008 => "hid0"
    1009 => "hid1"
    1010 => "iabr"
    1013 => "dabr"
    1017 => "l2cr"
    1019 => "ictc"
    1020 => "thrm1"
    1021 => "thrm2"
    1022 => "thrm3"
    _ => "{spr}"
}

# ============================================================
# Primary opcode 3: twi (Trap Word Immediate)
# ============================================================
twi         [0:5]=000011 to:u5[6:10] ra:gpr[11:15] simm:simm16[16:31]
            | "twi {to}, {ra}, {simm}"

# ============================================================
# Primary opcode 4: Paired Single
# ============================================================

# PS Compare - X-form
ps_cmpu0    [0:5]=000100 crfd:u3[6:8] [9:10]=00 fa:fpr[11:15] fb:fpr[16:20] [21:30]=0000000000 [31]=0
            | "ps_cmpu0 cr{crfd}, {fa}, {fb}"

ps_cmpo0    [0:5]=000100 crfd:u3[6:8] [9:10]=00 fa:fpr[11:15] fb:fpr[16:20] [21:30]=0000100000 [31]=0
            | "ps_cmpo0 cr{crfd}, {fa}, {fb}"

ps_cmpu1    [0:5]=000100 crfd:u3[6:8] [9:10]=00 fa:fpr[11:15] fb:fpr[16:20] [21:30]=0001000000 [31]=0
            | "ps_cmpu1 cr{crfd}, {fa}, {fb}"

ps_cmpo1    [0:5]=000100 crfd:u3[6:8] [9:10]=00 fa:fpr[11:15] fb:fpr[16:20] [21:30]=0001100000 [31]=0
            | "ps_cmpo1 cr{crfd}, {fa}, {fb}"

# PS Unary/Move - X-form ([11:15]=00000)
ps_res      [0:5]=000100 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0000011000 rc:bool[31]
            | "ps_res{rc ? .} {fd}, {fb}"

ps_rsqrte   [0:5]=000100 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0000011010 rc:bool[31]
            | "ps_rsqrte{rc ? .} {fd}, {fb}"

ps_neg      [0:5]=000100 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0000101000 rc:bool[31]
            | "ps_neg{rc ? .} {fd}, {fb}"

ps_mr       [0:5]=000100 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0001001000 rc:bool[31]
            | "ps_mr{rc ? .} {fd}, {fb}"

ps_nabs     [0:5]=000100 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0010001000 rc:bool[31]
            | "ps_nabs{rc ? .} {fd}, {fb}"

ps_abs      [0:5]=000100 fd:fpr[6:10] [11:15]=00000 fb:fpr[16:20] [21:30]=0100001000 rc:bool[31]
            | "ps_abs{rc ? .} {fd}, {fb}"

# PS Merge - X-form
ps_merge00  [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:30]=1000010000 rc:bool[31]
            | "ps_merge00{rc ? .} {fd}, {fa}, {fb}"

ps_merge01  [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:30]=1000110000 rc:bool[31]
            | "ps_merge01{rc ? .} {fd}, {fa}, {fb}"

ps_merge10  [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:30]=1001010000 rc:bool[31]
            | "ps_merge10{rc ? .} {fd}, {fa}, {fb}"

ps_merge11  [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:30]=1001110000 rc:bool[31]
            | "ps_merge11{rc ? .} {fd}, {fa}, {fb}"

# Quantized Load/Store - X-form
psq_lx      [0:5]=000100 fd:fpr[6:10] ra:gpr[11:15] rb:gpr[16:20] w:bool[21] i:u3[22:24] [25:30]=000110 [31]=0
            | "psq_lx {fd}, {ra}, {rb}, {w}, {i}"

psq_stx     [0:5]=000100 fs:fpr[6:10] ra:gpr[11:15] rb:gpr[16:20] w:bool[21] i:u3[22:24] [25:30]=000111 [31]=0
            | "psq_stx {fs}, {ra}, {rb}, {w}, {i}"

psq_lux     [0:5]=000100 fd:fpr[6:10] ra:gpr[11:15] rb:gpr[16:20] w:bool[21] i:u3[22:24] [25:30]=100110 [31]=0
            | "psq_lux {fd}, {ra}, {rb}, {w}, {i}"

psq_stux    [0:5]=000100 fs:fpr[6:10] ra:gpr[11:15] rb:gpr[16:20] w:bool[21] i:u3[22:24] [25:30]=100111 [31]=0
            | "psq_stux {fs}, {ra}, {rb}, {w}, {i}"

# PS Arithmetic - A-form (5-bit XO at [26:30])
ps_sum0     [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=01010 rc:bool[31]
            | "ps_sum0{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_sum1     [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=01011 rc:bool[31]
            | "ps_sum1{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_muls0    [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] [16:20]=00000 fc:fpr[21:25] [26:30]=01100 rc:bool[31]
            | "ps_muls0{rc ? .} {fd}, {fa}, {fc}"

ps_muls1    [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] [16:20]=00000 fc:fpr[21:25] [26:30]=01101 rc:bool[31]
            | "ps_muls1{rc ? .} {fd}, {fa}, {fc}"

ps_madds0   [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=01110 rc:bool[31]
            | "ps_madds0{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_madds1   [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=01111 rc:bool[31]
            | "ps_madds1{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_div      [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10010 rc:bool[31]
            | "ps_div{rc ? .} {fd}, {fa}, {fb}"

ps_sub      [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10100 rc:bool[31]
            | "ps_sub{rc ? .} {fd}, {fa}, {fb}"

ps_add      [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] [21:25]=00000 [26:30]=10101 rc:bool[31]
            | "ps_add{rc ? .} {fd}, {fa}, {fb}"

ps_sel      [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=10111 rc:bool[31]
            | "ps_sel{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_mul      [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] [16:20]=00000 fc:fpr[21:25] [26:30]=11001 rc:bool[31]
            | "ps_mul{rc ? .} {fd}, {fa}, {fc}"

ps_msub     [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11100 rc:bool[31]
            | "ps_msub{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_madd     [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11101 rc:bool[31]
            | "ps_madd{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_nmsub    [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11110 rc:bool[31]
            | "ps_nmsub{rc ? .} {fd}, {fa}, {fc}, {fb}"

ps_nmadd    [0:5]=000100 fd:fpr[6:10] fa:fpr[11:15] fb:fpr[16:20] fc:fpr[21:25] [26:30]=11111 rc:bool[31]
            | "ps_nmadd{rc ? .} {fd}, {fa}, {fc}, {fb}"

# Locked Cache Instruction
dcbz_l      [0:5]=000100 [6:10]=00000 ra:gpr[11:15] rb:gpr[16:20] [21:30]=1111110110 [31]=0
            | "dcbz_l {ra}, {rb}"

# ============================================================
# Primary opcode 7: mulli
# ============================================================
mulli       [0:5]=000111 rd:gpr[6:10] ra:gpr[11:15] simm:simm16[16:31]
            | "mulli {rd}, {ra}, {simm}"

# ============================================================
# Primary opcode 8: subfic
# ============================================================
subfic      [0:5]=001000 rd:gpr[6:10] ra:gpr[11:15] simm:simm16[16:31]
            | "subfic {rd}, {ra}, {simm}"

# ============================================================
# Primary opcodes 10-15: Compare/Arithmetic D-form
# ============================================================
cmpli       [0:5]=001010 crfd:u3[6:8] [9]=0 l:bool[10] ra:gpr[11:15] uimm:uimm[16:31]
            | l == 0, crfd == 0 : "cmplwi {ra}, {uimm}"
            | l == 0            : "cmplwi cr{crfd}, {ra}, {uimm}"
            | "cmpli {crfd}, {l}, {ra}, {uimm}"

cmpi        [0:5]=001011 crfd:u3[6:8] [9]=0 l:bool[10] ra:gpr[11:15] simm:simm16[16:31]
            | l == 0, crfd == 0 : "cmpwi {ra}, {simm}"
            | l == 0            : "cmpwi cr{crfd}, {ra}, {simm}"
            | "cmpi {crfd}, {l}, {ra}, {simm}"

addic       [0:5]=001100 rd:gpr[6:10] ra:gpr[11:15] simm:simm16[16:31]
            | simm < 0 : "subic {rd}, {ra}, {-simm}"
            | "addic {rd}, {ra}, {simm}"

addic_dot   [0:5]=001101 rd:gpr[6:10] ra:gpr[11:15] simm:simm16[16:31]
            | simm < 0 : "subic. {rd}, {ra}, {-simm}"
            | "addic. {rd}, {ra}, {simm}"

addi        [0:5]=001110 rd:gpr[6:10] ra:gpr[11:15] simm:simm16[16:31]
            | ra == 0  : "li {rd}, {simm}"
            | simm < 0 : "subi {rd}, {ra}, {-simm}"
            | "addi {rd}, {ra}, {simm}"

addis       [0:5]=001111 rd:gpr[6:10] ra:gpr[11:15] simm:simm16[16:31]
            | ra == 0  : "lis {rd}, {simm}"
            | simm < 0 : "subis {rd}, {ra}, {-simm}"
            | "addis {rd}, {ra}, {simm}"

# ============================================================
# Primary opcode 16: bcx (Branch Conditional)
# ============================================================
bcx         [0:5]=010000 bo:u5[6:10] bi:u5[11:15] bd:branch_disp[16:29] aa:bool[30] lk:bool[31]
            | bo >= 12, bo <= 15 : "b{bc_cond_true(bi % 4)}{bc_hint(bo % 2)}{lk ? l}{aa ? a} {bc_cr_prefix(bi / 4)}{bd}"
            | bo >= 4 , bo <= 7  : "b{bc_cond_false(bi % 4)}{bc_hint(bo % 2)}{lk ? l}{aa ? a} {bc_cr_prefix(bi / 4)}{bd}"
            | bo >= 16, bo <= 17 : "bdnz{bc_hint(bo % 2)}{lk ? l}{aa ? a} {bd}"
            | bo >= 18, bo <= 19 : "bdz{bc_hint(bo % 2)}{lk ? l}{aa ? a} {bd}"
            | "bc{lk ? l}{aa ? a} {bo}, {bi}, {bd}"

# ============================================================
# Primary opcode 17: sc (System Call)
# ============================================================
sc          [0:5]=010001 [6:29]=000000000000000000000000 [30]=1 [31]=0

# ============================================================
# Primary opcode 18: bx (Branch)
# ============================================================
bx          [0:5]=010010 li:simm24[6:29] aa:bool[30] lk:bool[31]
            | "b{lk ? l}{aa ? a} {li}"

# ============================================================
# Primary opcode 19: XL-form (Branch to LR/CTR, CR ops, etc.)
# ============================================================
mcrf        [0:5]=010011 crfd:u3[6:8] [9:10]=00 crfs:u3[11:13] [14:20]=0000000 [21:30]=0000000000 [31]=0
            | "mcrf cr{crfd}, cr{crfs}"

bclrx       [0:5]=010011 bo:u5[6:10] bi:u5[11:15] [16:20]=00000 [21:30]=0000010000 lk:bool[31]
            | bo == 20, bi == 0  : "blr{lk ? l}"
            | bo >= 12, bo <= 15 : "b{bc_cond_true(bi % 4)}lr{bc_hint(bo % 2)}{lk ? l}{bclr_cr(bi / 4)}"
            | bo >= 4 , bo <= 7  : "b{bc_cond_false(bi % 4)}lr{bc_hint(bo % 2)}{lk ? l}{bclr_cr(bi / 4)}"
            | bo >= 16, bo <= 17 : "bdnzlr{bc_hint(bo % 2)}{lk ? l}"
            | bo >= 18, bo <= 19 : "bdzlr{bc_hint(bo % 2)}{lk ? l}"
            | "bclr{lk ? l} {bo}, {bi}"

crnor       [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0000100001 [31]=0
            | crba == crbb : "crnot {crbd}, {crba}"
            | "crnor {crbd}, {crba}, {crbb}"

rfi         [0:5]=010011 [6:10]=00000 [11:15]=00000 [16:20]=00000 [21:30]=0000110010 [31]=0

crandc      [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0010000001 [31]=0
            | "crandc {crbd}, {crba}, {crbb}"

isync       [0:5]=010011 [6:10]=00000 [11:15]=00000 [16:20]=00000 [21:30]=0010010110 [31]=0

crxor       [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0011000001 [31]=0
            | crbd == crba, crba == crbb : "crclr {crbd}"
            | "crxor {crbd}, {crba}, {crbb}"

crnand      [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0011100001 [31]=0
            | "crnand {crbd}, {crba}, {crbb}"

crand       [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0100000001 [31]=0
            | "crand {crbd}, {crba}, {crbb}"

creqv       [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0100100001 [31]=0
            | crbd == crba, crba == crbb : "crset {crbd}"
            | "creqv {crbd}, {crba}, {crbb}"

crorc       [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0110100001 [31]=0
            | "crorc {crbd}, {crba}, {crbb}"

cror        [0:5]=010011 crbd:u5[6:10] crba:u5[11:15] crbb:u5[16:20] [21:30]=0111000001 [31]=0
            | crba == crbb : "crmove {crbd}, {crba}"
            | "cror {crbd}, {crba}, {crbb}"

bcctrx      [0:5]=010011 bo:u5[6:10] bi:u5[11:15] [16:20]=00000 [21:30]=1000010000 lk:bool[31]
            | bo == 20, bi == 0  : "bctr{lk ? l}"
            | bo >= 12, bo <= 15 : "b{bc_cond_true(bi % 4)}ctr{bc_hint(bo % 2)}{lk ? l}{bclr_cr(bi / 4)}"
            | bo >= 4 , bo <= 7  : "b{bc_cond_false(bi % 4)}ctr{bc_hint(bo % 2)}{lk ? l}{bclr_cr(bi / 4)}"
            | "bcctr{lk ? l} {bo}, {bi}"

# ============================================================
# Primary opcodes 20-21, 23: Rotate M-form
# ============================================================
rlwimix     [0:5]=010100 rs:gpr[6:10] ra:gpr[11:15] sh:u5[16:20] mb:u5[21:25] me:u5[26:30] rc:bool[31]
            | sh == 32 - mb, me >= mb : "inslwi{rc ? .} {ra}, {rs}, {me - mb + 1}, {mb}"
            | sh == 31 - me, me >= mb : "insrwi{rc ? .} {ra}, {rs}, {me - mb + 1}, {mb}"
            | "rlwimi{rc ? .} {ra}, {rs}, {sh}, {mb}, {me}"

rlwinmx     [0:5]=010101 rs:gpr[6:10] ra:gpr[11:15] sh:u5[16:20] mb:u5[21:25] me:u5[26:30] rc:bool[31]
            | mb == 0 , me == 31      : "rotlwi{rc ? .} {ra}, {rs}, {sh}"
            | mb == 0 , me == 31 - sh : "slwi{rc ? .} {ra}, {rs}, {sh}"
            | me == 31, sh == 32 - mb : "srwi{rc ? .} {ra}, {rs}, {mb}"
            | sh == 0 , mb == 0       : "clrrwi{rc ? .} {ra}, {rs}, {31 - me}"
            | sh == 0 , me == 31      : "clrlwi{rc ? .} {ra}, {rs}, {mb}"
            | mb == 0                 : "extlwi{rc ? .} {ra}, {rs}, {me + 1}, {sh}"
            | me == 31 - sh           : "clrlslwi{rc ? .} {ra}, {rs}, {mb + sh}, {sh}"
            | me == 31, sh + mb >= 32 : "extrwi{rc ? .} {ra}, {rs}, {32 - mb}, {sh + mb - 32}"
            | "rlwinm{rc ? .} {ra}, {rs}, {sh}, {mb}, {me}"

rlwnmx      [0:5]=010111 rs:gpr[6:10] ra:gpr[11:15] rb:gpr[16:20] mb:u5[21:25] me:u5[26:30] rc:bool[31]
            | mb == 0, me == 31 : "rotlw{rc ? .} {ra}, {rs}, {rb}"
            | "rlwnm{rc ? .} {ra}, {rs}, {rb}, {mb}, {me}"

# ============================================================
# Primary opcodes 24-29: Logical Immediate D-form
# ============================================================
ori         [0:5]=011000 rs:gpr[6:10] ra:gpr[11:15] uimm:uimm[16:31]
            | rs == 0, ra == 0, uimm == 0 : "nop"
            | "ori {ra}, {rs}, {uimm}"

oris        [0:5]=011001 rs:gpr[6:10] ra:gpr[11:15] uimm:uimm[16:31]
            | "oris {ra}, {rs}, {uimm}"

xori        [0:5]=011010 rs:gpr[6:10] ra:gpr[11:15] uimm:uimm[16:31]
            | "xori {ra}, {rs}, {uimm}"

xoris       [0:5]=011011 rs:gpr[6:10] ra:gpr[11:15] uimm:uimm[16:31]
            | "xoris {ra}, {rs}, {uimm}"

andi_dot    [0:5]=011100 rs:gpr[6:10] ra:gpr[11:15] uimm:uimm[16:31]
            | "andi. {ra}, {rs}, {uimm}"

andis_dot   [0:5]=011101 rs:gpr[6:10] ra:gpr[11:15] uimm:uimm[16:31]
            | "andis. {ra}, {rs}, {uimm}"

# ============================================================
# Primary opcode 31: X-form and XO-form
# ============================================================

# --- Integer Compare X-form ---
cmp         [0:5]=011111 crfd:u3[6:8] [9]=0 l:bool[10] ra:gpr[11:15] rb:gpr[16:20] [21:30]=0000000000 [31]=0
            | l == 0, crfd == 0 : "cmpw {ra}, {rb}"
            | l == 0            : "cmpw cr{crfd}, {ra}, {rb}"
            | "cmp {crfd}, {l}, {ra}, {rb}"

# --- Trap X-form ---
tw          [0:5]=011111 to:u5[6:10] ra:gpr[11:15] rb:gpr[16:20] [21:30]=0000000100 [31]=0
            | to == 31, ra == 0, rb == 0 : "trap"
            | "tw {to}, {ra}, {rb}"

# --- Integer Arithmetic XO-form (9-bit XO at [22:30]) ---
subfcx      [0:5]=011111 rd:gpr[6:10] ra:gpr[11:15] rb:gpr[16:20] oe:bool[21] [22:30]=000001000 rc:bool[31]
            | "subfc{oe ? o}{rc ? .} {rd}, {ra}, {rb}"

